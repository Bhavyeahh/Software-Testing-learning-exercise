digraph MoneyPolyCFG {
  rankdir=TB;
  splines=ortho;
  node [shape=box, style="rounded,filled", color="#3b4b6b", fillcolor="#eef3ff", fontname="Helvetica", fontsize=10];
  edge [color="#4a5d80", arrowsize=0.8, fontname="Helvetica", fontsize=9];

  start [label="Start turn\ncurrent_player()"];
  jail_check [label="Is player.in_jail?"];
  jail_handle [label="_handle_jail_turn(player)"];
  eliminated_after_jail [label="Is player eliminated?"];
  advance_after_jail [label="advance_turn()\nreturn"];

  roll [label="roll = dice.roll()"];
  doubles_3 [label="doubles_streak >= 3 ?"];
  send_jail [label="player.go_to_jail()\nadvance_turn()\nreturn"];

  move_resolve [label="_move_and_resolve(player, roll)"];
  eliminated_after_move [label="Is player eliminated?"];
  doubles_check [label="is_doubles() ?"];
  extra_turn [label="Extra turn\nreturn"];
  normal_advance [label="advance_turn()\nreturn"];
  end [label="End turn", shape=oval, fillcolor="#f7f7f7"];

  start -> jail_check;
  jail_check -> jail_handle [label="Yes"];
  jail_check -> roll [label="No"];

  jail_handle -> eliminated_after_jail;
  eliminated_after_jail -> end [label="Yes"];
  eliminated_after_jail -> advance_after_jail [label="No"];
  advance_after_jail -> end;

  roll -> doubles_3;
  doubles_3 -> send_jail [label="Yes"];
  doubles_3 -> move_resolve [label="No"];
  send_jail -> end;

  move_resolve -> eliminated_after_move;
  eliminated_after_move -> end [label="Yes"];
  eliminated_after_move -> doubles_check [label="No"];

  doubles_check -> extra_turn [label="Yes"];
  doubles_check -> normal_advance [label="No"];
  extra_turn -> end;
  normal_advance -> end;
}
